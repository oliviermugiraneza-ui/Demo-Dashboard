# ─── Production environment template ─────────────────────────────────────────
# Copy to .env.production and fill in real values, OR set these as Cloud Run
# environment variables (preferred — no file needed on Cloud Run).
#
# Cloud Run reads environment variables directly; .env.production is only a
# fallback for local production-mode testing (NODE_ENV=production npm start).

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="...."

# ─── Server ───────────────────────────────────────────────────────────────────
# Cloud Run injects PORT automatically — do not set it here
# PORT=8080

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated Firebase Hosting origins that are allowed to call the API
ALLOWED_ORIGINS=https://your-project.web.app,https://demo.wayve.ai

# ─── Notifications ────────────────────────────────────────────────────────────
NOTIFICATIONS_ENABLED=true
NOTIFICATION_DRY_RUN=false

# ─── Gmail / Google OAuth ─────────────────────────────────────────────────────
GOOGLE_EMAIL_PROVIDER=gmail_api
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
EMAIL_FROM=demo-ops@wayve.ai
