{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/server"
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", "frontend", "dist"]
}
