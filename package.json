{
  "name": "demo-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,UI -c cyan,magenta \"npm run server\" \"npm run frontend\"",
    "server": "NODE_ENV=development tsx watch server/index.ts",
    "frontend": "cd frontend && npm run dev",
    "build:server": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:server && npm run build:frontend",
    "start": "NODE_ENV=production node dist/server/index.js",
    "preview": "cd frontend && npm run preview",
    "deploy:firebase": "npm run build:frontend && firebase deploy --only hosting",
    "deploy:cloudrun": "gcloud run deploy demo-dashboard --source . --region us-central1 --platform managed --allow-unauthenticated",
    "migrate-backlog": "tsx scripts/migrate-backlog.ts",
    "import-backlog": "tsx scripts/import-backlog.ts",
    "migrate-notifications": "tsx scripts/migrate-notifications.ts",
    "get-gmail-token": "tsx scripts/get-gmail-token.ts",
    "migrate-post-demo": "tsx scripts/migrate-post-demo.ts",
    "seed-post-demo": "tsx scripts/seed-post-demo.ts",
    "migrate-admin-users": "tsx scripts/migrate-admin-users.ts",
    "migrate-demo-ref": "tsx scripts/migrate-demo-ref.ts",
    "backfill-demo-ref": "tsx scripts/backfill-demo-ref.ts",
    "normalise-admin-users": "tsx scripts/normalise-admin-users.ts",
    "migrate-demo-status": "tsx scripts/migrate-demo-status.ts",
    "db:audit": "tsx scripts/audit-database.ts",
    "db:cleanup": "tsx scripts/cleanup-database.ts",
    "db:verify": "tsx scripts/verify-database-clean.ts",
    "db:migrate-readiness": "tsx scripts/migrate-production-readiness.ts",
    "db:health": "tsx scripts/database-health.ts",
    "db:migrate-lakebase": "tsx scripts/migrate-lakebase.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5"
  }
}
